.page {
  padding: 24rpx;
  min-height: 100vh;
  background: #f6f7fb;
  box-sizing: border-box;
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
}

.sub {
  margin-top: 8rpx;
  margin-bottom: 20rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.card {
  background: #fff;
  border-radius: 14rpx;
  padding: 20rpx;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 16rpx;
}

.label {
  font-size: 24rpx;
  color: #374151;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

.input {
  height: 72rpx;
  border: 1px solid #d1d5db;
  border-radius: 10rpx;
  padding: 0 18rpx;
  margin-bottom: 14rpx;
  background: #fff;
}

.result .row {
  display: flex;
  margin-bottom: 10rpx;
}

.k {
  color: #6b7280;
  font-size: 24rpx;
  min-width: 160rpx;
}

.v {
  color: #111827;
  font-size: 24rpx;
  word-break: break-all;
}

.danger {
  color: #dc2626;
  font-weight: 700;
}
