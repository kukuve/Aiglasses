page {
  --primary-color: #07c160;
  --primary-dark: #06ad56;
  --primary-light: #e8f8ee;
  --text-color: #333333;
  --text-secondary: #999999;
  --text-placeholder: #cccccc;
  --border-color: #e5e5e5;
  --error-color: #ee0a24;
  --warning-color: #ff976a;
  --success-color: #07c160;
  --bg-color: #f7f8fa;
  --white: #ffffff;
  --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.06);
  --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.08);
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-xl: 24rpx;
  --font-size-xs: 24rpx;
  --font-size-sm: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 44rpx;
  --spacing-xs: 8rpx;
  --spacing-sm: 12rpx;
  --spacing-md: 16rpx;
  --spacing-lg: 24rpx;
  --spacing-xl: 32rpx;
  --spacing-xxl: 48rpx;
  box-sizing: border-box;
  background-color: var(--bg-color);
  color: var(--text-color);
  font-size: var(--font-size-md);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

view,
scroll-view,
swiper,
movable-view,
cover-view {
  box-sizing: border-box;
}

button {
  box-sizing: border-box;
}

input {
  box-sizing: border-box;
}