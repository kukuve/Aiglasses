/* ── Page Container ─────────────────────────────────────── */
.page-container {
  min-height: 100vh;
  padding: 40rpx 28rpx 80rpx;
  background: linear-gradient(180deg, var(--primary-color) 0%, var(--primary-dark) 220rpx, var(--bg-color) 220rpx);
  box-sizing: border-box;
}

/* ── Hero Header ───────────────────────────────────────── */
.hero {
  display: flex;
  justify-content: space-between;
  align-items: center;
  color: var(--white);
  margin-bottom: 28rpx;
}

.hero-actions {
  display: flex;
  gap: 10rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.api-btn {
  background: rgba(7, 193, 96, 0.22);
  color: #fff;
  border: 1px solid rgba(255,255,255,0.28);
  font-size: 24rpx;
  padding: 8rpx 20rpx;
}

/* ── API Picker Panel ──────────────────────────────────── */
.api-picker {
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.api-picker-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 16rpx;
}

.api-option {
  padding: 20rpx;
  border-radius: var(--radius-md);
  margin-bottom: 12rpx;
  border: 2rpx solid var(--border-color);
  transition: all 0.2s;
}

.api-option.selected {
  border-color: var(--primary-color);
  background: var(--primary-light);
}

.api-option.disabled {
  opacity: 0.5;
}

.api-option-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.api-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
}

.api-check {
  color: var(--primary-color);
  font-weight: 700;
}

.api-badge {
  font-size: 20rpx;
  color: var(--warning-color);
  background: #fff7ed;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.api-badge-ok {
  font-size: 20rpx;
  color: var(--primary-color);
  background: #e8f8ef;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
}

.api-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  display: block;
}

.api-picker-hint {
  font-size: 22rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: 8rpx;
}

/* ── API Key Row (inside picker) ───────────────────────── */
.api-key-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--border-color);
}

.api-key-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.api-key-details {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
}

.api-key-masked {
  font-size: 22rpx;
  color: var(--text-secondary);
  font-family: monospace;
}

.api-key-model {
  font-size: 20rpx;
  color: var(--primary-color);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.api-key-delete {
  font-size: 22rpx;
  color: var(--error-color);
  padding: 4rpx 8rpx;
}

.api-key-btn {
  font-size: 22rpx;
  background: var(--bg-color);
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
  padding: 6rpx 16rpx;
  line-height: 1.5;
}

/* ── API Key Config Modal ──────────────────────────────── */
.config-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.config-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  width: 100%;
  max-width: 640rpx;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
}

.config-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.config-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color);
}

.config-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.config-body {
  padding: 24rpx 28rpx;
}

.config-provider-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--primary-color);
  margin-bottom: 20rpx;
}

.config-field {
  margin-bottom: 20rpx;
}

.config-label {
  display: block;
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-bottom: 10rpx;
}

.config-input {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 2rpx solid var(--border-color);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-color);
  background: var(--bg-color);
  box-sizing: border-box;
}

.config-input:focus {
  border-color: var(--primary-color);
}

.config-field-hint {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 6rpx;
  line-height: 1.4;
}

.config-tips {
  margin-top: 16rpx;
}

.config-tip {
  display: block;
  font-size: 22rpx;
  color: var(--primary-color);
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.config-tip-warn {
  display: block;
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-top: 8rpx;
  line-height: 1.5;
}

.config-footer {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 0 28rpx 28rpx;
}

.config-btn-test {
  font-size: 26rpx;
  background: var(--bg-color);
  color: var(--primary-color);
  border: 1rpx solid var(--primary-color);
  padding: 10rpx 28rpx;
  line-height: 1.5;
}

.config-btn-test[disabled] {
  opacity: 0.5;
}

.config-btn-save {
  font-size: 26rpx;
  background: var(--primary-color);
  color: var(--white);
  border: none;
  padding: 10rpx 28rpx;
  line-height: 1.5;
}

.config-btn-save[disabled] {
  opacity: 0.5;
}

/* ── Empty State ───────────────────────────────────────── */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: var(--text-color);
  font-weight: 600;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--text-secondary);
  margin-top: 12rpx;
}

/* ── Results Section ───────────────────────────────────── */
.results-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-color);
}

.section-count {
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
}

/* ── Result Card ───────────────────────────────────────── */
.result-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.thumb {
  width: 100%;
  height: 100%;
}

.card-body {
  padding: 24rpx;
}

.card-row {
  display: flex;
  margin-bottom: 12rpx;
  align-items: flex-start;
}

.description-row {
  flex-direction: column;
}

.label {
  font-size: 24rpx;
  color: var(--text-secondary);
  min-width: 120rpx;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: var(--text-color);
  flex: 1;
}

.desc-text {
  margin-top: 8rpx;
  line-height: 1.7;
  font-size: 28rpx;
}

/* ── Tags ──────────────────────────────────────────────── */
.tags-row, .popup-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 12rpx 0;
}

.tag {
  font-size: 22rpx;
  color: var(--primary-color);
  background: var(--primary-light);
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
}

/* ── Card Meta ─────────────────────────────────────────── */
.card-meta {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--border-color);
}

.meta-item {
  font-size: 22rpx;
  color: var(--text-secondary);
  background: var(--bg-color);
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
}

.meta-item.time {
  margin-left: auto;
  background: none;
}

.confidence-high { color: var(--success-color); }
.confidence-medium { color: var(--warning-color); }
.confidence-low { color: var(--error-color); }

/* ── Popup Overlay ─────────────────────────────────────── */
.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  padding: 40rpx;
}

.popup-card {
  background: var(--white);
  border-radius: var(--radius-xl);
  width: 100%;
  max-height: 80vh;
  overflow-y: auto;
  box-shadow: 0 8px 32px rgba(0,0,0,0.15);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 28rpx 0;
}

.popup-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-color);
}

.popup-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 10rpx;
}

.popup-image {
  margin: 20rpx 28rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  max-height: 400rpx;
}

.popup-thumb {
  width: 100%;
  max-height: 400rpx;
}

.popup-body {
  padding: 0 28rpx;
}

.popup-row {
  margin-bottom: 12rpx;
  font-size: 28rpx;
  color: var(--text-color);
}

.popup-label {
  color: var(--text-secondary);
  font-size: 26rpx;
}

.popup-desc {
  font-size: 28rpx;
  color: var(--text-color);
  line-height: 1.7;
  margin: 16rpx 0;
  padding: 16rpx;
  background: var(--bg-color);
  border-radius: var(--radius-md);
}

.popup-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 28rpx 28rpx;
}

.popup-model {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.popup-btn {
  background: var(--primary-color);
  color: var(--white);
  border: none;
}

/* ── Skeleton ──────────────────────────────────────────── */
.skeleton-list {
  display: grid;
  gap: 16rpx;
}

.skeleton-card {
  background: var(--white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-sm);
  padding: 24rpx;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f2f5 25%, #e6e9ed 37%, #f0f2f5 63%);
  background-size: 400% 100%;
  border-radius: 999rpx;
  animation: shimmer 1.4s ease infinite;
  margin-bottom: 12rpx;
}

.skeleton-line:last-child { margin-bottom: 0; }
.skeleton-line.wide { width: 80%; }
.skeleton-line.mid { width: 60%; }
.skeleton-line.narrow { width: 40%; }

@keyframes shimmer {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
