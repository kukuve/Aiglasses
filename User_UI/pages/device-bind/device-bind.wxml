<view class="page">
  <view class="card">
    <text class="title">智能眼镜绑定</text>
    <text class="desc">登录后手机号会自动绑定，直接输入或扫码 Device_ID 即可。</text>

    <view class="field">
      <text class="label">Device_ID</text>
      <input
        class="input"
        placeholder="请输入包装盒上的 Device_ID"
        value="{{deviceId}}"
        maxlength="32"
        bindinput="onDeviceInput"
      />
    </view>

    <button class="btn ghost" bindtap="scanDeviceId">扫码读取 Device_ID</button>
    <button class="btn primary" bindtap="bindDevice" loading="{{submitting}}" disabled="{{submitting}}">确认绑定</button>
  </view>
</view>
