<view class="page">
  <view class="title">敏感数据查询</view>
  <view class="sub">仅超级管理员可查看，需提供管理员密钥</view>

  <view class="card">
    <view class="label">管理员密钥</view>
    <input
      class="input"
      password="true"
      placeholder="请输入 SUPER_ADMIN_KEY"
      value="{{adminKey}}"
      bindinput="onAdminKeyInput"
    />

    <view class="label">用户ID</view>
    <input
      class="input"
      placeholder="请输入 userId"
      value="{{userId}}"
      bindinput="onUserIdInput"
    />

    <view class="label">手机号（可选）</view>
    <input
      class="input"
      placeholder="或输入手机号（支持+国家码）"
      value="{{phone}}"
      bindinput="onPhoneInput"
    />

    <button type="primary" loading="{{loading}}" bindtap="querySensitive">按用户ID/手机号查询</button>
  </view>

  <view wx:if="{{sensitive}}" class="card result">
    <view class="row"><text class="k">用户ID：</text><text class="v">{{sensitive.userId}}</text></view>
    <view class="row"><text class="k">账号：</text><text class="v">{{sensitive.account || '--'}}</text></view>
    <view class="row"><text class="k">手机号：</text><text class="v">{{sensitive.phone || '--'}}</text></view>
    <view class="row"><text class="k">明文密码：</text><text class="v danger">{{sensitive.passwordPlain || '--'}}</text></view>
    <view class="row"><text class="k">更新时间：</text><text class="v">{{sensitive.updatedAtText}}</text></view>
  </view>
</view>
