<view class="page-container">
  <view class="header-bar">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <text class="header-title">欢迎回来</text>
    <view class="placeholder"></view>
  </view>

  <view class="form-container">
    <view class="welcome-section">
      <text class="welcome-title">登录账号</text>
      <text class="welcome-desc">输入已注册手机号和密码，登录后直接进入单词学习页</text>
    </view>

    <view class="form-group {{accountFocus ? 'form-group-focused' : ''}} {{accountError ? 'form-group-error' : ''}}">
      <view class="input-label">手机号/账号</view>
      <view class="input-wrapper">
        <text class="input-prefix-icon">📱</text>
        <input
          class="form-input"
          type="text"
          placeholder="请输入手机号"
          placeholder-class="input-placeholder"
          value="{{account}}"
          bindinput="onAccountInput"
          bindfocus="onAccountFocus"
          bindblur="onAccountBlur"
          maxlength="20"
        />
        <view class="input-clear {{account ? 'visible' : ''}}" bindtap="clearAccount">
          <text class="clear-icon">✕</text>
        </view>
      </view>
      <view class="error-tip {{accountError ? 'visible' : ''}}">{{accountErrorMessage}}</view>
    </view>

    <view class="form-group {{passwordFocus ? 'form-group-focused' : ''}} {{passwordError ? 'form-group-error' : ''}}">
      <view class="input-label">密码</view>
      <view class="input-wrapper">
        <text class="input-prefix-icon">🔒</text>
        <input
          class="form-input"
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          bindfocus="onPasswordFocus"
          bindblur="onPasswordBlur"
          maxlength="20"
        />
        <view class="input-toggle" bindtap="togglePassword">
          <text class="toggle-icon">{{showPassword ? '👁' : '🙈'}}</text>
        </view>
      </view>
      <view class="error-tip {{passwordError ? 'visible' : ''}}">{{passwordErrorMessage}}</view>
    </view>

    <view class="form-options">
      <view class="remember-me" bindtap="toggleRemember">
        <view class="checkbox {{rememberMe ? 'checked' : ''}}">
          <text class="check-icon" wx:if="{{rememberMe}}">✓</text>
        </view>
        <text class="option-text">记住账号</text>
      </view>
      <text class="forgot-password" bindtap="forgotPassword">忘记密码？</text>
    </view>

    <button class="login-btn {{isLoading ? 'loading' : ''}}" bindtap="handleLogin" disabled="{{isLoading}}">
      <view class="loading-spinner" wx:if="{{isLoading}}">
        <view class="spinner-item"></view>
        <view class="spinner-item"></view>
        <view class="spinner-item"></view>
      </view>
      <text wx:if="{{!isLoading}}">登录并进入单词页</text>
      <text wx:elif="{{isLoading}}">登录中...</text>
    </button>

    <view class="register-link">
      <text class="link-text">还没有账号？</text>
      <text class="link-action" bindtap="goToRegister">立即注册</text>
    </view>
  </view>
</view>
